<% layout('layouts/boilerplate') %>
<body>
    <h2>All Listings</h2>
    <ul>
        <% for(listing of listings) { %>
            <li><a href="/listings/<%= listing._id %>"><%= listing.title %></a></li>
        <% }%>
    </ul>
    <form method="GET" action="/listings/new">
        <button>Add</button>
    </form>
</body>
